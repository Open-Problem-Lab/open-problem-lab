{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://open-problem-lab.local/schemas/evidence.schema.json",
  "title": "Evidence Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "problem_id",
    "claim",
    "evidence_type",
    "source",
    "source_date",
    "access_date",
    "method",
    "limitations",
    "confidence"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "problem_id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*/[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "claim": {
      "type": "string",
      "minLength": 20
    },
    "evidence_type": {
      "type": "string",
      "enum": [
        "primary-source",
        "dataset",
        "peer-reviewed-study",
        "field-report",
        "expert-review",
        "replication",
        "negative-result"
      ]
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "url"],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 4
        },
        "url": {
          "type": "string",
          "format": "uri"
        }
      }
    },
    "source_date": {
      "type": "string",
      "format": "date"
    },
    "access_date": {
      "type": "string",
      "format": "date"
    },
    "method": {
      "type": "string",
      "minLength": 10
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 5
      },
      "minItems": 1
    },
    "confidence": {
      "type": "string",
      "enum": ["high", "medium", "low", "unknown"]
    }
  }
}
